@page
@model MuruganRestaurant.Pages.Dashboard.IndexModel
@{
    ViewData["Title"] = "Dashboard - Murugan Restaurant";
}

<!-- ── ROW 1: Today + Month + All-Time ── -->
<div class="row g-3 mb-3">

    <!-- Today's Bills -->
    <div class="col-xl-3 col-md-6">
        <div class="stat-card">
            <div class="si" style="background:#fff7ed;color:#f97316;">
                <i class="fas fa-receipt"></i>
            </div>
            <div>
                <div class="sl">Today's Bills</div>
                <div class="sv">@Model.TodayBillsCount</div>
            </div>
        </div>
    </div>

    <!-- Today's Revenue -->
    <div class="col-xl-3 col-md-6">
        <div class="stat-card">
            <div class="si" style="background:#dcfce7;color:#16a34a;">
                <i class="fas fa-rupee-sign"></i>
            </div>
            <div>
                <div class="sl">Today's Revenue</div>
                <div class="sv sm">₹@Model.TodayRevenue.ToString("N0")</div>
            </div>
        </div>
    </div>

    <!-- This Month Revenue -->
    <div class="col-xl-3 col-md-6">
        <div class="stat-card">
            <div class="si" style="background:var(--gold-bg);color:var(--gold);">
                <i class="fas fa-calendar-alt"></i>
            </div>
            <div>
                <div class="sl">This Month</div>
                <div class="sv sm">₹@Model.MonthRevenue.ToString("N0")</div>
                <div style="font-size:11px;color:var(--text-muted);margin-top:2px;">@Model.MonthBillsCount bills</div>
            </div>
        </div>
    </div>

    <!-- All-Time Revenue -->
    <div class="col-xl-3 col-md-6">
        <div class="stat-card">
            <div class="si" style="background:#eff6ff;color:#3b82f6;">
                <i class="fas fa-chart-line"></i>
            </div>
            <div>
                <div class="sl">All-Time Revenue</div>
                <div class="sv sm">₹@Model.TotalRevenue.ToString("N0")</div>
                <div style="font-size:11px;color:var(--text-muted);margin-top:2px;">@Model.TotalBillsCount total bills</div>
            </div>
        </div>
    </div>
</div>

<!-- ── ROW 2: Food Items + Users + Payment Breakdown ── -->
<div class="row g-3 mb-4">
    <div class="col-xl-3 col-md-6">
        <div class="stat-card">
            <div class="si" style="background:#fdf4ff;color:#a855f7;">
                <i class="fas fa-utensils"></i>
            </div>
            <div>
                <div class="sl">Food Items</div>
                <div class="sv">@Model.TotalFoodItems</div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="stat-card">
            <div class="si" style="background:#f0fdf4;color:#22c55e;">
                <i class="fas fa-users"></i>
            </div>
            <div>
                <div class="sl">Active Users</div>
                <div class="sv">@Model.TotalUsers</div>
            </div>
        </div>
    </div>

    <!-- Payment method breakdown spanning 2 cols -->
    <div class="col-xl-6 col-md-12">
        <div class="stat-card flex-column align-items-start" style="gap:8px;">
            <div class="sl" style="font-size:10px;">All-Time Revenue by Payment Method</div>
            <div class="rev-split w-100">
                <div class="rev-pill">
                    <div class="rp-label">💵 Cash</div>
                    <div class="rp-val">₹@Model.CashRevenue.ToString("N0")</div>
                </div>
                <div class="rev-pill">
                    <div class="rp-label">💳 Card</div>
                    <div class="rp-val">₹@Model.CardRevenue.ToString("N0")</div>
                </div>
                <div class="rev-pill">
                    <div class="rp-label">📱 UPI</div>
                    <div class="rp-val">₹@Model.UpiRevenue.ToString("N0")</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ── ROW 3: Quick Actions + Recent Bills ── -->
<div class="row g-3">
    <div class="col-xl-4 col-md-12">
        <div class="card h-100">
            <div class="card-header ch-gold">
                <i class="fas fa-bolt me-2"></i>Quick Actions
            </div>
            <div class="card-body d-flex flex-column gap-2 p-3">
                <a href="/Billing/Create" class="btn btn-navy w-100 text-start py-3">
                    <i class="fas fa-file-invoice-dollar me-2"></i> New Bill
                </a>
                <a href="/FoodItems/Index" class="btn btn-outline-secondary w-100 text-start">
                    <i class="fas fa-utensils me-2"></i> Manage Food Items
                </a>
                <a href="/Users/Index" class="btn btn-outline-secondary w-100 text-start">
                    <i class="fas fa-users-cog me-2"></i> Manage Users
                </a>
                <a href="/Reports/Index" class="btn btn-outline-secondary w-100 text-start">
                    <i class="fas fa-chart-bar me-2"></i> View Reports
                </a>
            </div>
        </div>
    </div>

    <div class="col-xl-8 col-md-12">
        <div class="card">
            <div class="card-header ch-navy d-flex justify-content-between align-items-center">
                <span><i class="fas fa-clock me-2" style="color:var(--gold-light);"></i>Recent Bills</span>
                <a href="/Reports/Index" class="btn-gold btn btn-sm px-3">View All</a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th class="ps-3">Bill No</th>
                                <th>Customer</th>
                                <th>Amount</th>
                                <th>Payment</th>
                                <th class="pe-3">Time</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.RecentBills != null && Model.RecentBills.Any())
                            {
                                @foreach (var bill in Model.RecentBills)
                                {
                                    <tr>
                                        <td class="ps-3"><small class="fw-bold" style="color:var(--navy);">@bill.BillNumber</small></td>
                                        <td>@(string.IsNullOrEmpty(bill.CustomerName) ? "Walk-in" : bill.CustomerName)</td>
                                        <td class="fw-bold" style="color:#16a34a;">₹@bill.TotalAmount.ToString("N0")</td>
                                        <td>
                                            <span class="badge-gold">@bill.PaymentMethod</span>
                                        </td>
                                        <td class="pe-3"><small style="color:var(--text-muted);">@bill.BillDate.ToString("dd-MM  HH:mm")</small></td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr><td colspan="5" class="text-center text-muted py-4">No bills yet</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
