@page
@model MuruganRestaurant.Pages.Billing.PrintModel
@{
    Layout = null;
    ViewData["Title"] = "Print Bill - Murugan Restaurant";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bill - Murugan Restaurant</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            font-size: 14px;
            line-height: 1.5;
            color: #333;
            background: #fff;
        }

        .bill-container {
            max-width: 400px;
            margin: 0 auto;
            padding: 20px;
            background: white;
        }

        .header {
            text-align: center;
            border-bottom: 2px dashed #333;
            padding-bottom: 15px;
            margin-bottom: 15px;
        }

            .header h1 {
                font-size: 24px;
                color: #d32f2f;
                margin-bottom: 5px;
            }

            .header p {
                font-size: 12px;
                color: #666;
                margin: 2px 0;
            }

        .bill-info {
            margin-bottom: 15px;
            padding: 10px;
            background: #f5f5f5;
            border-radius: 5px;
        }

            .bill-info p {
                margin: 5px 0;
                font-size: 12px;
            }

        .items-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 15px;
        }

            .items-table th {
                text-align: left;
                padding: 8px 5px;
                border-bottom: 1px solid #ddd;
                font-size: 12px;
                font-weight: bold;
            }

            .items-table td {
                padding: 8px 5px;
                border-bottom: 1px solid #eee;
                font-size: 12px;
            }

            .items-table .text-right {
                text-align: right;
            }

        .totals {
            border-top: 2px solid #333;
            padding-top: 10px;
            margin-top: 10px;
        }

        .totals-row {
            display: flex;
            justify-content: space-between;
            margin: 5px 0;
            font-size: 12px;
        }

        .grand-total {
            font-size: 18px;
            font-weight: bold;
            color: #d32f2f;
            border-top: 1px solid #ddd;
            padding-top: 10px;
            margin-top: 10px;
        }

        .footer {
            text-align: center;
            margin-top: 20px;
            padding-top: 15px;
            border-top: 2px dashed #333;
            font-size: 11px;
            color: #666;
        }

        .thankyou {
            text-align: center;
            font-size: 16px;
            font-weight: bold;
            color: #d32f2f;
            margin: 15px 0;
        }

        .print-button {
            text-align: center;
            margin-top: 20px;
            padding: 10px;
        }

        .btn-print {
            background-color: #4CAF50;
            color: white;
            padding: 10px 20px;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-size: 16px;
            margin-right: 10px;
        }

        .btn-close {
            background-color: #f44336;
            color: white;
            padding: 10px 20px;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-size: 16px;
        }

        @@media print {
            .print-button {
                display: none;
        }
        }

        body {
            margin: 0;
            padding: 0;
        }

        .bill-container {
            padding: 0;
        }
    </style>
</head>
<body>
    <div class="bill-container">
        <div class="header">
            <h1>🍽️ MURUGAN RESTAURANT</h1>
            <p>#123, Main Road, Chennai - 600001</p>
            <p>Phone: +91 98765 43210 | GST: 33AAAAA1234A1Z</p>
        </div>

        @if (Model.Bill != null)
        {
            <div class="bill-info">
                <p><strong>Bill No:</strong> @Model.Bill.BillNumber</p>
                <p><strong>Date:</strong> @Model.Bill.BillDate.ToString("dd-MM-yyyy hh:mm tt")</p>
                <p><strong>Customer:</strong> @(!string.IsNullOrEmpty(Model.Bill.CustomerName) ? Model.Bill.CustomerName : "Walk-in Customer")</p>
                <p><strong>Phone:</strong> @(!string.IsNullOrEmpty(Model.Bill.CustomerPhone) ? Model.Bill.CustomerPhone : "-")</p>
                <p><strong>Payment Mode:</strong> @Model.Bill.PaymentMethod</p>
                <p><strong>Billed By:</strong> @Model.UserName</p>
            </div>

            <table class="items-table">
                <thead>
                    <tr>
                        <th>Item</th>
                        <th class="text-right">Qty</th>
                        <th class="text-right">Price</th>
                        <th class="text-right">Total</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.BillItems != null && Model.BillItems.Any())
                    {
                        @foreach (var item in Model.BillItems)
                        {
                            <tr>
                                <td>@item.FoodItem?.FoodName</td>
                                <td class="text-right">@item.Quantity</td>
                                <td class="text-right">₹@item.UnitPrice.ToString("0.00")</td>
                                <td class="text-right">₹@item.TotalPrice.ToString("0.00")</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>

            <div class="totals">
                <div class="totals-row">
                    <span>Sub Total:</span>
                    <span>₹@Model.Bill.SubTotal.ToString("0.00")</span>
                </div>
                <div class="totals-row">
                    <span>Tax (5%):</span>
                    <span>₹@Model.Bill.Tax.ToString("0.00")</span>
                </div>
                @if (Model.Bill.Discount > 0)
                {
                    <div class="totals-row">
                        <span>Discount:</span>
                        <span>- ₹@Model.Bill.Discount.ToString("0.00")</span>
                    </div>
                }
            </div>

            <div class="grand-total">
                <div class="totals-row">
                    <span><strong>GRAND TOTAL:</strong></span>
                    <span><strong>₹@Model.Bill.TotalAmount.ToString("0.00")</strong></span>
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-danger">
                Bill not found!
            </div>
        }

        <div class="thankyou">
            Thank You! Visit Again
        </div>

        <div class="footer">
            <p>** This is a computer generated bill **</p>
            <p>** No signature required **</p>
            <p>For feedback: feedback@muruganrestaurant.com</p>
        </div>

        <div class="print-button">
            <button class="btn-print" onclick="window.print()">🖨️ Print Bill</button>
            
        </div>
    </div>

    <script>
        // Auto trigger print dialog after page loads
        window.onload = function() { return; // Auto-print disabled - using modal
            setTimeout(function() {
                window.print();
            }, 500);
        };

        // Optional: Close window after printing
        window.onafterprint = function() {
            // Uncomment if you want to auto-close after printing
            // setTimeout(function() { window.close(); }, 1000);
        };
    </script>
</body>
</html>