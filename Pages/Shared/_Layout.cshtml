<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Murugan Restaurant</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Cormorant+Garamond:wght@600;700&display=swap" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <style>
        :root {
            --navy:       #0f1729;
            --navy-mid:   #162040;
            --navy-light: #1e2d55;
            --gold:       #c9a84c;
            --gold-light: #e8c96d;
            --gold-glow:  rgba(201,168,76,0.18);
            --gold-bg:    rgba(201,168,76,0.08);
            --sidebar-w:  248px;
            --topbar-h:   58px;
            --text-main:  #0f1729;
            --text-muted: #64748b;
            --page-bg:    #f1f4fb;
            --card-r:     16px;
            --sidebar-text: #8fa3c8;
        }

        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--page-bg);
            color: var(--text-main);
        }

        /* ─── SIDEBAR ─── */
        #sidebar {
            position: fixed; top: 0; left: 0;
            width: var(--sidebar-w); height: 100vh;
            background: var(--navy);
            display: flex; flex-direction: column;
            z-index: 1000;
            box-shadow: 4px 0 24px rgba(0,0,0,0.18);
            transition: transform .3s ease;
        }

        /* Gold top accent bar */
        #sidebar::before {
            content: '';
            display: block;
            height: 3px;
            background: linear-gradient(90deg, var(--gold), var(--gold-light), var(--gold));
        }

        .sb-brand {
            padding: 20px 20px 16px;
            border-bottom: 1px solid rgba(255,255,255,0.06);
        }
        .sb-brand-icon {
            width: 42px; height: 42px;
            background: linear-gradient(135deg, var(--gold), var(--gold-light));
            border-radius: 12px;
            display: flex; align-items: center; justify-content: center;
            font-size: 22px;
            margin-bottom: 10px;
            box-shadow: 0 4px 14px rgba(201,168,76,0.35);
        }
        .sb-brand h5 {
            font-family: 'Cormorant Garamond', serif;
            color: #fff; font-size: 16px; font-weight: 700;
            letter-spacing: .3px; margin-bottom: 2px;
        }
        .sb-brand small { color: var(--sidebar-text); font-size: 11px; }

        .sb-nav { flex: 1; padding: 14px 12px; overflow-y: auto; }
        .sb-nav::-webkit-scrollbar { width: 0; }

        .sb-section {
            color: rgba(143,163,200,0.5);
            font-size: 9.5px; font-weight: 700;
            letter-spacing: 2px; text-transform: uppercase;
            padding: 16px 8px 6px;
        }

        .sb-link {
            display: flex; align-items: center; gap: 11px;
            padding: 10px 13px;
            border-radius: 11px;
            color: var(--sidebar-text);
            text-decoration: none;
            font-size: 13.5px; font-weight: 500;
            transition: all .18s;
            margin-bottom: 2px;
            position: relative;
        }
        .sb-link i { width: 18px; text-align: center; font-size: 14px; opacity: .8; }
        .sb-link:hover { background: rgba(255,255,255,0.05); color: #fff; }
        .sb-link:hover i { opacity: 1; }
        .sb-link.active {
            background: var(--gold-bg);
            color: var(--gold-light);
            font-weight: 600;
            border: 1px solid rgba(201,168,76,0.2);
        }
        .sb-link.active i { opacity: 1; color: var(--gold); }
        .sb-link.active::before {
            content: '';
            position: absolute; left: 0; top: 50%;
            transform: translateY(-50%);
            width: 3px; height: 60%;
            background: var(--gold);
            border-radius: 0 3px 3px 0;
        }

        .sb-footer {
            padding: 14px 16px;
            border-top: 1px solid rgba(255,255,255,0.06);
        }
        .sb-user {
            display: flex; align-items: center; gap: 10px;
        }
        .sb-avatar {
            width: 36px; height: 36px; border-radius: 10px;
            background: linear-gradient(135deg, var(--gold), var(--gold-light));
            display: flex; align-items: center; justify-content: center;
            color: var(--navy); font-weight: 800; font-size: 14px;
            flex-shrink: 0;
        }
        .sb-uname { color: #fff; font-size: 13px; font-weight: 600; }
        .sb-urole { color: var(--sidebar-text); font-size: 11px; }
        .sb-logout {
            margin-left: auto; color: var(--sidebar-text);
            background: none; border: none; cursor: pointer; font-size: 15px;
            transition: color .15s; padding: 4px;
        }
        .sb-logout:hover { color: #f87171; }

        /* ─── TOPBAR ─── */
        #topbar {
            position: fixed; top: 0;
            left: var(--sidebar-w); right: 0;
            height: var(--topbar-h);
            background: #fff;
            border-bottom: 1px solid #e4e9f2;
            display: flex; align-items: center;
            padding: 0 26px; gap: 16px;
            z-index: 900;
            box-shadow: 0 1px 8px rgba(15,23,41,0.06);
        }
        .topbar-title {
            font-size: 17px; font-weight: 700; color: var(--navy); flex: 1;
        }
        .topbar-chip {
            background: var(--gold-bg);
            border: 1px solid rgba(201,168,76,0.3);
            color: var(--gold);
            font-size: 11.5px; font-weight: 700;
            padding: 4px 12px; border-radius: 20px;
            letter-spacing: .3px;
        }
        #sbToggle { display: none; background: none; border: none; font-size: 18px; color: var(--navy); }

        /* ─── MAIN ─── */
        #main {
            margin-left: var(--sidebar-w);
            padding-top: var(--topbar-h);
            min-height: 100vh;
        }
        .content { padding: 26px; }

        /* ─── STAT CARDS ─── */
        .stat-card {
            background: #fff;
            border-radius: var(--card-r);
            padding: 22px 22px;
            display: flex; align-items: center; gap: 16px;
            box-shadow: 0 2px 14px rgba(15,23,41,0.07);
            border: 1px solid rgba(228,233,242,0.8);
            position: relative; overflow: hidden;
            transition: transform .18s, box-shadow .18s;
        }
        .stat-card:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(15,23,41,0.1); }
        .stat-card::after {
            content: ''; position: absolute;
            top: 0; right: 0;
            width: 80px; height: 80px;
            border-radius: 50%;
            background: currentColor;
            opacity: .04;
            transform: translate(20px,-20px);
        }
        .si {
            width: 54px; height: 54px; border-radius: 14px;
            display: flex; align-items: center; justify-content: center;
            font-size: 22px; flex-shrink: 0;
        }
        .sl { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .8px; color: var(--text-muted); }
        .sv { font-size: 28px; font-weight: 800; color: var(--navy); line-height: 1.1; }
        .sv.sm { font-size: 20px; }
        .stat-divider { width: 1px; height: 40px; background: #e4e9f2; margin: 0 6px; }

        /* ─── CARDS ─── */
        .card {
            border: 1px solid rgba(228,233,242,0.8);
            border-radius: var(--card-r);
            box-shadow: 0 2px 12px rgba(15,23,41,0.06);
        }
        .card-header {
            border-radius: var(--card-r) var(--card-r) 0 0 !important;
            font-weight: 700; font-size: 14px;
            border-bottom: 1px solid rgba(228,233,242,0.6);
            padding: 15px 20px;
        }
        .ch-navy { background: var(--navy); color: #fff; border-color: transparent; }
        .ch-gold  { background: linear-gradient(135deg,var(--gold),var(--gold-light)); color: var(--navy); border-color: transparent; }
        .ch-white { background: #fff; color: var(--navy); }

        /* ─── BUTTONS ─── */
        .btn-gold {
            background: linear-gradient(135deg, var(--gold), var(--gold-light));
            color: var(--navy); border: none; font-weight: 700;
            border-radius: 10px;
        }
        .btn-gold:hover { filter: brightness(1.08); color: var(--navy); }
        .btn-navy {
            background: var(--navy); color: #fff; border: none; font-weight: 700;
            border-radius: 10px;
        }
        .btn-navy:hover { background: var(--navy-light); color: #fff; }

        /* Keep orange aliases for old pages */
        .btn-orange { background: linear-gradient(135deg,var(--gold),var(--gold-light)); color: var(--navy); border: none; font-weight: 700; border-radius:10px; }
        .btn-orange:hover { filter: brightness(1.08); color: var(--navy); }
        .ch-orange { background: linear-gradient(135deg,var(--gold),var(--gold-light)); color: var(--navy); border-color: transparent; }
        .ch-dark { background: var(--navy); color: #fff; border-color: transparent; }

        /* ─── TABLES ─── */
        .table th {
            font-size: 11.5px; font-weight: 700;
            text-transform: uppercase; letter-spacing: .6px;
            color: var(--text-muted); border-bottom: 2px solid #e4e9f2;
        }
        .table td { font-size: 13.5px; vertical-align: middle; }
        .table-hover tbody tr:hover { background: var(--gold-bg); }

        /* ─── FORMS ─── */
        .form-control, .form-select {
            border-radius: 10px; font-size: 13.5px;
            border: 1.5px solid #e4e9f2;
            font-family: 'DM Sans', sans-serif;
        }
        .form-control:focus, .form-select:focus {
            border-color: var(--gold);
            box-shadow: 0 0 0 3px var(--gold-glow);
        }
        label { font-size: 12.5px; font-weight: 600; color: var(--text-muted); margin-bottom: 5px; }

        /* ─── BADGES ─── */
        .badge-gold { background: var(--gold-bg); color: var(--gold); border: 1px solid rgba(201,168,76,0.3); font-weight: 700; padding: 4px 10px; border-radius: 20px; font-size: 12px; }

        /* Revenue split row */
        .rev-split {
            display: flex; gap: 12px; flex-wrap: wrap; margin-top: 10px;
        }
        .rev-pill {
            flex: 1; min-width: 80px;
            background: var(--page-bg);
            border-radius: 10px; padding: 10px 14px;
            border: 1px solid #e4e9f2;
            text-align: center;
        }
        .rev-pill .rp-label { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: .5px; color: var(--text-muted); }
        .rev-pill .rp-val { font-size: 16px; font-weight: 800; color: var(--navy); }

        /* ─── MOBILE ─── */
        @@media (max-width: 768px) {
            #sidebar { transform: translateX(-100%); }
            #sidebar.open { transform: translateX(0); }
            #topbar, #main { left: 0; margin-left: 0; }
            #sbToggle { display: block; }
        }
    </style>
</head>
<body>

@if (User.Identity != null && User.Identity.IsAuthenticated)
{
    var initials = (User.Identity.Name ?? "U").Substring(0, 1).ToUpper();
    var role = User.IsInRole("Admin") ? "Administrator" : "Staff";
    var path = Context.Request.Path.Value ?? "";

    <nav id="sidebar">
        <div class="sb-brand">
                <div class="sb-brand-icon">🍽️</div>
            <h5>Murugan Restaurant</h5>
            <small>Billing Management System</small>
        </div>

        <div class="sb-nav">
            @if (User.IsInRole("Admin"))
            {
                <div class="sb-section">Main</div>
                <a href="/Dashboard/Index" class="sb-link @(path.Contains("Dashboard") ? "active" : "")">
                    <i class="fas fa-th-large"></i> Dashboard
                </a>
                <a href="/Billing/Create" class="sb-link @(path.Contains("Billing") ? "active" : "")">
                    <i class="fas fa-file-invoice-dollar"></i> Billing
                </a>
                <div class="sb-section">Management</div>
                <a href="/FoodItems/Index" class="sb-link @(path.Contains("FoodItems") ? "active" : "")">
                    <i class="fas fa-utensils"></i> Food Items
                </a>
                <a href="/Users/Index" class="sb-link @(path.Contains("Users") ? "active" : "")">
                    <i class="fas fa-users-cog"></i> Users
                </a>
                <a href="/Reports/Index" class="sb-link @(path.Contains("Reports") ? "active" : "")">
                    <i class="fas fa-chart-bar"></i> Reports
                </a>
            }
            else
            {
                <div class="sb-section">Menu</div>
                <a href="/Billing/Create" class="sb-link @(path.Contains("Billing") ? "active" : "")">
                    <i class="fas fa-file-invoice-dollar"></i> Billing
                </a>
            }
        </div>

        <div class="sb-footer">
            <div class="sb-user">
                <div class="sb-avatar">@initials</div>
                <div>
                    <div class="sb-uname">@User.Identity.Name</div>
                    <div class="sb-urole">@role</div>
                </div>
                <a href="/Account/Logout" class="sb-logout" title="Logout">
                    <i class="fas fa-sign-out-alt"></i>
                </a>
            </div>
        </div>
    </nav>

    <div id="topbar">
        <button id="sbToggle" onclick="document.getElementById('sidebar').classList.toggle('open')">
            <i class="fas fa-bars"></i>
        </button>
        <div class="topbar-title">@(ViewData["Title"]?.ToString()?.Split('-')[0].Trim() ?? "Dashboard")</div>
            <span class="topbar-chip">🍽️ Murugan Restaurant</span>
    </div>

    <div id="main">
        <div class="content">
            @RenderBody()
        </div>
    </div>
}
else
{
    @RenderBody()
}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
